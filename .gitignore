# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build / next
/.next/
/out/
/build
# env
.env
.env.local
.env.*.local
.env.protonrefs.local

# logs / debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
.DS_Store
*.tsbuildinfo

# simulator local run artifacts (regenerate with npm run sim:run)
.simulation-results/

# ephemeral human report outputs (keep README only)
simulator/reports/output/*
!simulator/reports/output/README.md

# local terraform plugin cache (reference policy pack)
iac/**/.terraform/
iac/**/terraform.tfstate
iac/**/terraform.tfstate.backup
iac/**/crash.log
