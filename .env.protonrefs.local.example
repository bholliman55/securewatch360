# Copy this file to .env.protonrefs.local (gitignored).
# Each value should be a Proton Pass secret reference:
# pass://<vault-name>/<item-name>/<field-name>
# Assumes Proton vault/item names:
#   Vault: SecureWatch360
#   Item:  securewatch360-dev

# Core platform
NEXT_PUBLIC_SUPABASE_URL=pass://SecureWatch360/securewatch360-dev/NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=pass://SecureWatch360/securewatch360-dev/NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=pass://SecureWatch360/securewatch360-dev/SUPABASE_SERVICE_ROLE_KEY
INNGEST_EVENT_KEY=pass://SecureWatch360/securewatch360-dev/INNGEST_EVENT_KEY
INNGEST_SIGNING_KEY=pass://SecureWatch360/securewatch360-dev/INNGEST_SIGNING_KEY

# AI features
ANTHROPIC_API_KEY=pass://SecureWatch360/securewatch360-dev/ANTHROPIC_API_KEY

# Bright Data external intelligence
BRIGHTDATA_API_KEY=pass://SecureWatch360/securewatch360-dev/BRIGHTDATA_API_KEY
BRIGHTDATA_WEB_UNLOCKER_ZONE=pass://SecureWatch360/securewatch360-dev/BRIGHTDATA_WEB_UNLOCKER_ZONE
BRIGHTDATA_SERP_ZONE=pass://SecureWatch360/securewatch360-dev/BRIGHTDATA_SERP_ZONE
BRIGHTDATA_BROWSER_ZONE=pass://SecureWatch360/securewatch360-dev/BRIGHTDATA_BROWSER_ZONE

# Scanner integrations
TENABLE_ACCESS_KEY=pass://SecureWatch360/securewatch360-dev/TENABLE_ACCESS_KEY
TENABLE_SECRET_KEY=pass://SecureWatch360/securewatch360-dev/TENABLE_SECRET_KEY
TENABLE_INGEST_TOKEN=pass://SecureWatch360/securewatch360-dev/TENABLE_INGEST_TOKEN
SEMGREP_APP_TOKEN=pass://SecureWatch360/securewatch360-dev/SEMGREP_APP_TOKEN

# ConnectWise (ticketing flow)
CONNECTWISE_BASE_URL=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_BASE_URL
CONNECTWISE_COMPANY_ID=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_COMPANY_ID
CONNECTWISE_PUBLIC_KEY=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_PUBLIC_KEY
CONNECTWISE_PRIVATE_KEY=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_PRIVATE_KEY
CONNECTWISE_SERVICE_COMPANY_ID=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_SERVICE_COMPANY_ID
CONNECTWISE_BOARD_ID=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_BOARD_ID
CONNECTWISE_STATUS_ID=pass://SecureWatch360/securewatch360-dev/CONNECTWISE_STATUS_ID

# Jira
JIRA_BASE_URL=pass://SecureWatch360/securewatch360-dev/JIRA_BASE_URL
JIRA_EMAIL=pass://SecureWatch360/securewatch360-dev/JIRA_EMAIL
JIRA_API_TOKEN=pass://SecureWatch360/securewatch360-dev/JIRA_API_TOKEN
JIRA_PROJECT_KEY=pass://SecureWatch360/securewatch360-dev/JIRA_PROJECT_KEY

# ServiceNow
SERVICENOW_INSTANCE=pass://SecureWatch360/securewatch360-dev/SERVICENOW_INSTANCE
SERVICENOW_USER=pass://SecureWatch360/securewatch360-dev/SERVICENOW_USER
SERVICENOW_PASSWORD=pass://SecureWatch360/securewatch360-dev/SERVICENOW_PASSWORD
