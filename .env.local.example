# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: service role for trusted jobs (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Inngest — local dev: run `npm run inngest:dev` in a second terminal (UI at http://localhost:8288).
# With the Dev Server, you can use a placeholder INNGEST_EVENT_KEY; signing is relaxed.
# For Docker/explicit dev mode: INNGEST_DEV=1 and optionally INNGEST_BASE_URL (default http://localhost:8288)
INNGEST_EVENT_KEY=
# Production / preview: from Inngest Cloud → app → keys
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
INNGEST_BASE_URL=http://127.0.0.1:8288
