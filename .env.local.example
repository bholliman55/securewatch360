# Decision engine / OPA (optional)
DECISION_ENGINE_PROVIDER=rules
OPA_BASE_URL=http://localhost:8181
OPA_POLICY_PATH=/v1/data/securewatch/v4/decision
OPA_POLICY_EVAL_URL=
