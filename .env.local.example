# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: service role for trusted jobs (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Inngest — local dev: run `npm run inngest:dev` in a second terminal (UI at http://localhost:8288).
# With the Dev Server, you can use a placeholder INNGEST_EVENT_KEY; signing is relaxed.
# For Docker/explicit dev mode: INNGEST_DEV=1 and optionally INNGEST_BASE_URL (default http://localhost:8288)
INNGEST_EVENT_KEY=
# Production / preview: from Inngest Cloud → app → keys
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
INNGEST_BASE_URL=http://127.0.0.1:8288
ZAP_BASELINE_COMMAND=C:\Users\brent\source\securewatch360\scripts\zap-baseline.cmd

# Remediation safety mode: true enables human-in-the-loop for high-risk actions
REMEDIATION_HUMAN_IN_THE_LOOP=true
REMEDIATION_EXEC_ISOLATE_COMMAND=
REMEDIATION_EXEC_VLAN_COMMAND=
REMEDIATION_EXEC_PATCH_COMMAND=
REMEDIATION_EXEC_REIMAGE_COMMAND=
REMEDIATION_EXEC_DEFAULT_COMMAND=

# Optional awareness-training signals (comma-separated)
SECURITY_AWARENESS_REAL_WORLD_SIGNALS=
SECURITY_AWARENESS_COMPANY_SIGNALS=

# Optional scheduled awareness-signal ingestion
AWARENESS_SIGNAL_TENANT_IDS=
AWARENESS_REAL_WORLD_SIGNALS_URL=
AWARENESS_COMPANY_SIGNALS_URL=

# Optional machine auth for GET /api/policy/catalog and /api/policy/export/*
POLICY_PACK_EXPORT_TOKEN=
POLICY_PACK_EXPORT_TENANT_IDS=

# Scanner connectors (Agent 2 / Agent 5)
TENABLE_BASE_URL=https://cloud.tenable.com
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
TENABLE_INGEST_TOKEN=
SEMGREP_API_URL=https://semgrep.dev/api/v1
SEMGREP_APP_TOKEN=

# Real-connector QA targets
QA_TENABLE_TARGET=
QA_SEMGREP_REPO=

# ConnectWise Manage (PSA) — /api/integrations/connectwise/tickets
# API base: company site URL with path ending in .../apis/3.0  (e.g. .../v4_6_release/apis/3.0)
CONNECTWISE_BASE_URL=
# API login: companyId + public key as username, private key as password (per ConnectWise REST docs)
CONNECTWISE_COMPANY_ID=
CONNECTWISE_PUBLIC_KEY=
CONNECTWISE_PRIVATE_KEY=
# Shown in API headers as clientId
CONNECTWISE_CLIENT_ID=securewatch360
# Target service company, board, and new-ticket status (integer ids from your CW site)
CONNECTWISE_SERVICE_COMPANY_ID=
CONNECTWISE_BOARD_ID=
CONNECTWISE_STATUS_ID=
# Priority id used when a severity mapping is not set. Also used as default for P_* below.
CONNECTWISE_DEFAULT_PRIORITY_ID=
# Optional: override per level (defaults to CONNECTWISE_DEFAULT_PRIORITY_ID for each)
CONNECTWISE_PRIORITY_LOW=
CONNECTWISE_PRIORITY_MEDIUM=
CONNECTWISE_PRIORITY_HIGH=
CONNECTWISE_PRIORITY_CRITICAL=
