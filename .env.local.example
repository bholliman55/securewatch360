SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# Test tenant ID
TEST_TENANT_ID=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
INNGEST_BASE_URL=http://127.0.0.1:8288
