{
  "name": "securewatch360",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names \"next,inngest\" --prefix-colors \"cyan,yellow\" \"npm run dev\" \"npm run inngest:dev\"",
    "inngest:dev": "node scripts/inngest-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:sim": "vitest run simulator/tests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "sim:list": "npx tsx simulator/cli/listScenarios.ts",
    "sim:run": "npx tsx simulator/cli/runScenario.ts",
    "sim:run-all": "npx tsx simulator/cli/runAll.ts",
    "sim:report": "npx tsx simulator/cli/generateReport.ts",
    "sim:replay": "npx tsx simulator/cli/replayScenario.ts",
    "sim:chaos": "npx tsx simulator/cli/runChaos.ts",
    "policy:verify": "npx tsx policy/testing/cli/runPolicyVerify.ts",
    "demo:stack": "node scripts/demo-stack.mjs",
    "demo:stack:staging": "node scripts/demo-stack-staging.mjs",
    "demo:seed": "tsx scripts/demo/seed-investor-demo.ts",
    "demo:reset": "tsx scripts/demo/reset-investor-demo.ts",
    "demo:run": "tsx scripts/demo/run-investor-demo.ts",
    "seed:v4": "npx tsx scripts/seed-v4.ts",
    "seed:cve-catalog": "node scripts/seed-cve-catalog.mjs",
    "seed:posture-roadmap": "node scripts/seed-posture-roadmap.mjs",
    "seed:posture-roadmap-demo": "node scripts/seed-posture-roadmap-demo.mjs",
    "generate:policy-pack-iac": "node scripts/generate-policy-pack-iac.mjs",
    "generate:compliance-templates": "node scripts/generate-framework-org-template-stubs.mjs",
    "generate:compliance-templates:all": "node scripts/generate-framework-org-template-stubs.mjs --all",
    "qa:v4:e2e": "npx tsx scripts/qa-v4-e2e.ts",
    "qa:v4:agents": "npx tsx scripts/qa-v4-agents-e2e.ts",
    "qa:hipaa:operational": "npx tsx scripts/qa-hipaa-operational.ts",
    "qa:frameworks:operational": "npx tsx scripts/qa-frameworks-operational.ts",
    "qa:frameworks:opa-required": "set REQUIRE_OPA=1 && npx tsx scripts/qa-frameworks-operational.ts",
    "qa:frameworks:compliance": "npx tsx scripts/qa-frameworks-compliance-operational.ts",
    "qa:v4:hardening": "npx tsx scripts/qa-v4-hardening.ts",
    "qa:v4:chaos": "npx tsx scripts/qa-v4-chaos.ts",
    "qa:opa-optional": "npx tsx scripts/qa-opa-optional.ts",
    "qa:token-optimization": "npx tsx scripts/qa-token-optimization.ts",
    "qa:token-estimator": "npx tsx scripts/qa-token-estimator-examples.ts",
    "qa:external-intel": "npx tsx scripts/qa-external-intelligence.ts",
    "qa:prompt-hash": "npx tsx scripts/qa-prompt-hash-examples.ts",
    "qa:context-sanitizer": "npx tsx scripts/qa-context-sanitizer-examples.ts",
    "qa:context-compressor": "npx tsx scripts/qa-context-compressor-examples.ts",
    "qa:v1:connectors:real": "npx tsx scripts/qa-v1-connectors-real.ts",
    "qa:policy-pack": "npx tsx scripts/qa-policy-pack-validate.ts",
    "qa:iac": "npx tsx scripts/qa-iac-policy-pack-validate.ts",
    "qa:rego": "npx tsx scripts/qa-rego-opa-check.ts",
    "qa:policy-qa": "npm run qa:policy-pack && npm run qa:iac && npm run qa:rego",
    "security:audit": "npm audit --audit-level=high",
    "security:sast": "npx semgrep --config p/owasp-top-ten --config p/secrets --error",
    "security:infra": "trivy fs --scanners vuln,misconfig,secret --severity HIGH,CRITICAL .",
    "security:dast:local": "scripts\\zap-baseline.cmd -t http://host.docker.internal:3000 -m 2",
    "security:baseline": "npm run security:audit && npm run security:sast && npm run security:infra",
    "dev:proton-pass": "pwsh ./scripts/dev-with-proton-pass.ps1",
    "reset:posture-roadmap-demo": "node scripts/reset-posture-roadmap-demo.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "inngest": "^3.54.0",
    "lucide-react": "^1.14.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "protobufjs": ">=7.2.5",
    "@opentelemetry/otlp-transformer": {
      "protobufjs": ">=8.1.0"
    },
    "next": {
      "postcss": ">=8.5.10"
    }
  }
}
